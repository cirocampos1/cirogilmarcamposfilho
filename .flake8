[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501, W291, W293
exclude =
    .agent,
    .venv,
    .git,
    __pycache__,
    build,
    dist,
    node_modules,
    venv,
    env

per-file-ignores =
    scripts/*: E402
    scripts/dashboards/validate_dashboard_generator.py: E402, F401
    backups/*: E402
